{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "PORT": "3001",
    "ADMIN_PASSCODE": "@admin_passcode",
    "STORAGE_PATH": "/tmp/content-store.json"
  }
}
