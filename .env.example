# Frontend - where to reach the backend API
VITE_API_BASE_URL=http://localhost:3001

# Backend - admin passcode (optional, defaults to veeboss-admin)
ADMIN_PASSCODE=veeboss-admin

# Backend - storage path (optional, defaults to server/content-store.json)
STORAGE_PATH=./content-store.json

# Optional: Supabase credentials for real-time sync (if you want real-time instead of polling)
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
